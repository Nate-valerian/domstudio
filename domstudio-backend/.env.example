DATABASE_URL=postgresql+asyncpg://domstudio:change-me@localhost/domstudio
JWT_SECRET=generate-a-long-random-secret

TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

YANDEX_PAY_MERCHANT_ID=
YANDEX_PAY_SECRET=

# SMS OTP — get api_id at https://sms.ru (Settings → API)
SMS_API_KEY=
SMS_SENDER=DomStudio

# Email OTP — get key at https://resend.com (free tier: 3k emails/mo)
RESEND_API_KEY=
EMAIL_FROM=DomStudio <noreply@domstudio.site>

FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
GENERATION_API_URL=http://localhost:8001
GENERATION_PROVIDER=worker

# Set GENERATION_PROVIDER=comfy to run exported ComfyUI API workflows.
# COMFYUI_URL wins when set. Otherwise AutoDL discovery uses AUTODL_*.
COMFYUI_URL=
COMFYUI_PORT=6006
COMFYUI_API_KEY=
# Comfy.org account key for paid Partner/API nodes such as ByteDance, Kling, Luma, Wan API.
COMFYUI_ACCOUNT_API_KEY=
COMFYUI_IMAGE_WORKFLOW=product_image.json
COMFYUI_VIDEO_WORKFLOW=product_video.json
COMFYUI_VIDEO_RESOLUTION=720p
COMFYUI_WORKFLOW_DIR=
COMFYUI_POLL_TIMEOUT=600
COMFYUI_POLL_INTERVAL=2
AUTODL_API_URL=https://api.autodl.com
AUTODL_TOKEN=
# Preferred for AutoDL instance/pro snapshot discovery.
AUTODL_INSTANCE_UUID=
# Legacy elastic deployment discovery is still supported.
AUTODL_DEPLOYMENT_UUID=

# Optional prompt expansion for image-edit scene requests.
# If empty, backend uses the built-in fallback prompt builder.
DEEPSEEK_API_KEY=

CORS_ORIGINS=http://localhost:5173
