DATABASE_URL=postgresql+asyncpg://domstudio:change-me@localhost/domstudio
JWT_SECRET=generate-a-long-random-secret

TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

YANDEX_PAY_MERCHANT_ID=
YANDEX_PAY_SECRET=

# SMS OTP — get api_id at https://sms.ru (Settings → API)
SMS_API_KEY=
SMS_SENDER=DomStudio

# Email OTP — get key at https://resend.com (free tier: 3k emails/mo)
RESEND_API_KEY=
EMAIL_FROM=DomStudio <noreply@domstudio.site>
CONTACT_TO_EMAIL=hello@domstudio.site

# Production frontend: https://domstudio.site, or http://domstudio.site while SSL is not active.
FRONTEND_URL=http://localhost:3000
# Production API on Amvera currently uses the .amvera.io host, not .amvera.ru.
API_URL=http://localhost:8000
GENERATION_API_URL=http://localhost:8001
GENERATION_PROVIDER=worker

# Set GENERATION_PROVIDER=comfy to run exported ComfyUI API workflows.
# COMFYUI_URL wins when set. Otherwise AutoDL discovery uses AUTODL_*.
COMFYUI_URL=
COMFYUI_PORT=6006
COMFYUI_API_KEY=
# Comfy.org account key for paid Partner/API nodes such as ByteDance, Kling, Luma, Wan API.
COMFYUI_ACCOUNT_API_KEY=
# Keep false for local/free Wan. Set true only when intentionally running a paid Partner workflow.
COMFYUI_ALLOW_PAID_PARTNER_NODES=false
COMFYUI_IMAGE_WORKFLOW=product_image.json
# Free local Wan I2V workflow. Premium ByteDance fallback: product_video.json.
COMFYUI_VIDEO_WORKFLOW=product_video_wan_local.json
COMFYUI_PREMIUM_VIDEO_WORKFLOW=product_video.json
COMFYUI_VIDEO_RESOLUTION=480p
COMFYUI_VIDEO_FPS=16
COMFYUI_WORKFLOW_DIR=
COMFYUI_POLL_TIMEOUT=600
COMFYUI_POLL_INTERVAL=2
AUTODL_API_URL=https://api.autodl.com
AUTODL_TOKEN=
# Preferred for AutoDL instance/pro snapshot discovery.
AUTODL_INSTANCE_UUID=
# Legacy elastic deployment discovery is still supported.
AUTODL_DEPLOYMENT_UUID=

# Optional prompt expansion for image-edit scene requests.
# If empty, backend uses the built-in fallback prompt builder.
DEEPSEEK_API_KEY=

# Optional OpenAI-compatible text backend for AdPilot/Copy Studio tools.
# If empty, /content/generate uses built-in local templates.
TEXT_AI_BASE_URL=http://localhost:8000/v1
TEXT_AI_API_KEY=
TEXT_AI_MODEL=qwen2.5-7b-instruct
TEXT_AI_TIMEOUT_MS=60000
TEXT_AI_MAX_TOKENS=700
CONTENT_TOKEN_UNIT=10
ADPILOT_CHAT_GUEST_DAILY_LIMIT=10
ADPILOT_CHAT_FREE_USER_DAILY_LIMIT=30
ADPILOT_CHAT_PAID_USER_DAILY_LIMIT=150
ADPILOT_CHAT_MAX_MESSAGES=10
ADPILOT_CHAT_MAX_TOKENS=900

# Groq vision for AdPilot product-photo analysis. Keep the key on the backend only.
GROQ_API_KEY=
GROQ_VISION_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_VISION_TIMEOUT_MS=60000
GROQ_VISION_MAX_TOKENS=500
GROQ_VISION_MAX_IMAGE_BYTES=8388608
GROQ_VISION_DAILY_LIMIT=20

# Optional explicit key for encrypted marketplace API credentials.
# If empty, the backend derives encryption from JWT_SECRET.
MARKETPLACE_ENCRYPTION_KEY=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://domstudio.vercel.app,http://domstudio.site,https://domstudio.site,http://www.domstudio.site,https://www.domstudio.site
