{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{image_name}}"
    }
  },
  "2": {
    "class_type": "ByteDanceImageToVideoNode",
    "inputs": {
      "model": "seedance-1-0-lite-i2v-250428",
      "prompt": "{{prompt}}",
      "image": ["1", 0],
      "resolution": "{{video_resolution}}",
      "aspect_ratio": "{{video_aspect_ratio}}",
      "duration": "{{duration_s}}",
      "seed": "{{seed}}",
      "camera_fixed": false,
      "watermark": false
    }
  },
  "3": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["2", 0],
      "filename_prefix": "domstudio/video/{{mode}}",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
